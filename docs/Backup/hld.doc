    <td class=3D"confluenceTd">=E2=80=94</td>
   </tr>
   <tr>
    <td class=3D"confluenceTd">Cluster reprovisioning</td>
    <td class=3D"confluenceTd">=E2=9C=94=EF=B8=8F</td>
    <td class=3D"confluenceTd">=E2=80=94</td>
    <td class=3D"confluenceTd">=E2=80=94</td>
   </tr>
  </tbody>
 </table>
</div>
<h3 id=3D"UpgradeOmniacorecontainerfrom2.0to2.1-3.5ArchitectureThreatModel"=
>3.5 Architecture Threat Model</h3>
<div class=3D"table-wrap">
 <table class=3D"confluenceTable">
  <thead>
   <tr>
    <th class=3D"confluenceTh">Threat</th>
    <th class=3D"confluenceTh">Impact</th>
    <th class=3D"confluenceTh">Likelihood</th>
    <th class=3D"confluenceTh">Mitigation</th>
   </tr>
  </thead>
  <tbody>
   <tr>
    <td class=3D"confluenceTd">Unauthorized upgrade execution</td>
    <td class=3D"confluenceTd">High</td>
    <td class=3D"confluenceTd">Low</td>
    <td class=3D"confluenceTd">Requires sudo/root access and explicit user =
confirmation prompt</td>
   </tr>
   <tr>
    <td class=3D"confluenceTd">Backup corruption/loss</td>
    <td class=3D"confluenceTd">High</td>
    <td class=3D"confluenceTd">Low</td>
    <td class=3D"confluenceTd">Backup manifest, integrity validation</td>
   </tr>
   <tr>
    <td class=3D"confluenceTd">Network failure during image pull</td>
    <td class=3D"confluenceTd">Medium</td>
    <td class=3D"confluenceTd">Medium</td>
    <td class=3D"confluenceTd">Pre-pull validation, retry logic, manual pul=
l instructions</td>
   </tr>
   <tr>
