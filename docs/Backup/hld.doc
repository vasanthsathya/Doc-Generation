    <td class=3D"confluenceTd">Rollback failure</td>
    <td class=3D"confluenceTd">Critical</td>
    <td class=3D"confluenceTd">Low</td>
    <td class=3D"confluenceTd">Manual recovery procedures documented, backu=
p preserved</td>
   </tr>
   <tr>
    <td class=3D"confluenceTd">Concurrent upgrade attempts</td>
    <td class=3D"confluenceTd">Medium</td>
    <td class=3D"confluenceTd">Low</td>
